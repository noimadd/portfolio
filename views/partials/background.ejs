<div class="background">
    <svg viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice">

    <defs>
        <filter id="glow">
        <feGaussianBlur stdDeviation="4" result="blur"/>
        <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
        </feMerge>
        </filter>
    </defs>

    <!-- OUTER RING -->
    <circle cx="960" cy="540" r="260"
            stroke="rgba(212,175,55,0.08)"
            stroke-width="1"
            fill="none"/>

    <!-- INNER RING -->
    <circle cx="960" cy="540" r="160"
            stroke="rgba(212,175,55,0.05)"
            stroke-width="1"
            fill="none"/>

    <!-- CONNECTIONS -->
    <g stroke="rgba(212,175,55,0.12)" stroke-width="1.2">

        <!-- Core branches -->
        <line x1="960" y1="540" x2="760" y2="380"/>
        <line x1="960" y1="540" x2="1160" y2="380"/>
        <line x1="960" y1="540" x2="960" y2="795"/>

        <!-- Left branch expansion -->
        <line x1="760" y1="380" x2="600" y2="300"/>
        <line x1="600" y1="300" x2="490" y2="260"/>
        <line x1="760" y1="380" x2="720" y2="200"/>
        <line x1="720" y1="200" x2="720" y2="120"/>

        <!-- Right branch expansion -->
        <line x1="1160" y1="380" x2="1320" y2="300"/>
        <line x1="1320" y1="300" x2="1430" y2="260"/>
        <line x1="1160" y1="380" x2="1200" y2="200"/>
        <line x1="1200" y1="200" x2="1200" y2="120"/>

        <!-- Bottom branch expansion -->
        <line x1="960" y1="795" x2="860" y2="900"/>
        <line x1="860" y1="900" x2="820" y2="980"/>
        <line x1="960" y1="795" x2="1060" y2="900"/>
        <line x1="1060" y1="900" x2="1100" y2="980"/>

    </g>

    <!-- NODES -->
    <g filter="url(#glow)">

        <!-- Keystone -->
        <circle cx="960" cy="540" r="14" fill="currentColor"/>

        <!-- Primary Notables -->
        <circle cx="760" cy="380" r="10" fill="currentColor"/>
        <circle cx="1160" cy="380" r="10" fill="currentColor"/>
        <circle cx="960" cy="795" r="10" fill="currentColor"/>

        <!-- Left outer minors -->
        <circle cx="600" cy="300" r="6"
                stroke="currentColor" stroke-width="2" fill="currentColor"/>
        <circle cx="490" cy="260" r="6"
                stroke="currentColor" stroke-width="2" fill="currentColor"/>
        <circle cx="720" cy="200" r="6"
                stroke="currentColor" stroke-width="2" fill="currentColor"/>
        <circle cx="720" cy="120" r="6"
                stroke="currentColor" stroke-width="2" fill="none"/>

        <!-- Right outer minors -->
        <circle cx="1320" cy="300" r="6"
                stroke="currentColor" stroke-width="2" fill="none"/>
        <circle cx="1430" cy="260" r="6"
                stroke="currentColor" stroke-width="2" fill="none"/>
        <circle cx="1200" cy="200" r="6"
                stroke="currentColor" stroke-width="2" fill="currentColor"/>
        <circle cx="1200" cy="120" r="6"
                stroke="currentColor" stroke-width="2" fill="currentColor"/>

        <!-- Bottom outer minors -->
        <circle cx="860" cy="900" r="6"
                stroke="currentColor" stroke-width="2" fill="currentColor"/>
        <circle cx="820" cy="980" r="6"
                stroke="currentColor" stroke-width="2" fill="none"/>
        <circle cx="1060" cy="900" r="6"
                stroke="currentColor" stroke-width="2" fill="none"/>
        <circle cx="1100" cy="980" r="6"
                stroke="currentColor" stroke-width="2" fill="none"/>

    </g>

    </svg>
</div>